{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/api_b2b_oauth_v1_b2b_oauth_discovery_AuthenticateRequest",
  "title": "api_b2b_oauth_v1_b2b_oauth_discovery_AuthenticateRequest",
  "type": "object",
  "properties": {
    "discovery_oauth_token": {
      "type": "string",
      "description": "The Discovery OAuth token to authenticate."
    },
    "session_token": {
      "type": "string"
    },
    "session_duration_minutes": {
      "type": "integer",
      "format": "int32"
    },
    "session_jwt": {
      "type": "string"
    },
    "session_custom_claims": {
      "type": "object",
      "additionalProperties": true
    },
    "pkce_code_verifier": {
      "type": "string",
      "description": "A base64url encoded one time secret used to validate that the request starts and ends on the same device."
    }
  },
  "description": "Request type",
  "required": [
    "discovery_oauth_token"
  ]
}